// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum SubscriptionTier {
  FREE
  ELITE
  MASTER
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  password         String
  phoneNumber      String?
  role             Role             @default(STUDENT)
  subscriptionTier SubscriptionTier @default(FREE)
  subscriptionEnds DateTime?        // null = FREE forever; set when ELITE/MASTER active
  avatarUrl        String?
  targetInstansi   String?
  jabatan          String?
  jenjang          String?
  prodi            String?
  gender           String?
  profession       String?
  learningWay      String?
  learningPref     String?
  source           String?
  learningGoal     String?
  notifEmail       Boolean          @default(true)
  isActive         Boolean          @default(true)
  hasGivenFeedback Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  sessions           Session[]
  examResults        ExamResult[]
  userAnswers        UserAnswer[]
  materialProgress   UserMaterialProgress[]
  subscriptions      Subscription[]
  transactions       Transaction[]
  psychometricResult PsychometricResult?
  iqResult           IQResult?
  testimonials       Testimonial[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum QuestionCategory {
  TWK
  TIU
  TKP
}

enum QuestionDifficulty {
  MUDAH
  SEDANG
  SULIT
}

model Question {
  id           String             @id @default(cuid())
  category     QuestionCategory
  subCategory  String
  content      String             // Rich text
  explanation  String             // Explanation text
  difficulty   QuestionDifficulty @default(SEDANG)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  options      Option[]
  exams        ExamQuestion[]
  userAnswers  UserAnswer[]

  @@map("questions")
}

model Option {
  id           String   @id @default(cuid())
  questionId   String
  text         String
  score        Int      @default(0)
  createdAt    DateTime @default(now())

  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("options")
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

enum ExamAccessTier {
  FREE
  ELITE
  MASTER
}

model Exam {
  id              String         @id @default(cuid())
  title           String
  durationMinutes Int
  passingGradeTWK Int            @default(65)
  passingGradeTIU Int            @default(80)
  passingGradeTKP Int            @default(166)
  status          ExamStatus     @default(DRAFT)
  accessTier      ExamAccessTier @default(FREE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  questions       ExamQuestion[]
  results         ExamResult[]
  userAnswers     UserAnswer[]

  @@map("exams")
}

model ExamQuestion {
  examId      String
  questionId  String
  order       Int

  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
  @@map("exam_questions")
}

// Stores individual answers per question during an exam session (resumable)
model UserAnswer {
  id          String   @id @default(cuid())
  userId      String
  examId      String
  questionId  String
  optionId    String?  // null = unanswered
  isRagu      Boolean  @default(false) // flagged for review
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, examId, questionId])
  @@map("user_answers")
}

// Stores the final aggregated result after exam submission
model ExamResult {
  id              String   @id @default(cuid())
  userId          String
  examId          String
  scoreTWK        Int      @default(0)
  scoreTIU        Int      @default(0)
  scoreTKP        Int      @default(0)
  totalScore      Int      @default(0)
  passTWK         Boolean  @default(false)
  passTIU         Boolean  @default(false)
  passTKP         Boolean  @default(false)
  overallPass     Boolean  @default(false)
  submittedAt     DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_results")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  subject     String
  htmlBody    String   // React/Email injected HTML template
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model SystemSetting {
  key   String @id
  value String

  @@map("system_settings")
}

// ─── Learning Hub ─────────────────────────────────────────────────────────────

enum MaterialType {
  TEXT
  VIDEO
  PDF
}

enum MaterialAccessTier {
  FREE
  ELITE
  MASTER
}

model Material {
  id           String             @id @default(cuid())
  title        String
  slug         String             @unique
  category     QuestionCategory   // TWK | TIU | TKP
  subCategory  String
  type         MaterialType       @default(TEXT)
  accessTier   MaterialAccessTier @default(FREE)
  difficulty   QuestionDifficulty @default(SEDANG)
  content      String             // Markdown/rich text body
  videoUrl     String?            // YouTube/Vimeo embed URL
  pdfUrl       String?            // PDF link or upload URL
  isPublished  Boolean            @default(false)
  order        Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  progress     UserMaterialProgress[]

  @@map("materials")
}

model UserMaterialProgress {
  id          String   @id @default(cuid())
  userId      String
  materialId  String
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
  @@map("user_material_progress")
}

// ─── Billing & Subscriptions ───────────────────────────────────────────────────

enum PlanType {
  FREE
  ELITE
  MASTER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum PaymentMethod {
  BANK_TRANSFER
  EWALLET
  QRIS
  CREDIT_CARD
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  planType    PlanType
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("subscriptions")
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  subscriptionId  String?
  planType        PlanType
  amount          Int               // in IDR cents (e.g. 14900000 = Rp149.000)
  status          TransactionStatus @default(PENDING)
  paymentMethod   PaymentMethod?
  snapToken       String?           // Midtrans Snap token
  externalId      String?           // Gateway order ID
  promoCode       String?
  discountAmount  Int               @default(0)
  durationMonths  Int               @default(1)
  paidAt          DateTime?
  expiredAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription    Subscription?     @relation(fields: [subscriptionId], references: [id])

  @@map("transactions")
}

model PaymentLog {
  id              String   @id @default(cuid())
  orderId         String?  // Can be transaction externalId or unknown
  event           String   // e.g., WEBHOOK_RECEIVED, SIGNATURE_MISMATCH, PAYMENT_SUCCESS
  payload         Json?    // Store the raw request body or relevant data
  status          String   // e.g., INFO, WARNING, ERROR, SUCCESS
  createdAt       DateTime @default(now())

  @@map("payment_logs")
}

enum LookupType {
  INSTANCE
  POSITION
  EDUCATION
  MAJOR
}

model Lookup {
  id        String     @id @default(cuid())
  name      String
  type      LookupType
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("lookups")
}

// ─── Psychometric & IQ Question Banks ─────────────────────────────────────────

// Bank soal Psikotes - dikelola via admin, mendukung Likert scale
model PsychQuestion {
  id             String   @id @default(cuid())
  text           String   // Teks pernyataan
  dimension      String   // e.g. "openness", "conscientiousness", etc.
  dimensionLabel String   // e.g. "Keterbukaan"
  isActive       Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("psych_questions")
}

// Bank soal IQ - mendukung pilihan ganda dengan kunci jawaban
model IQQuestion {
  id          String          @id @default(cuid())
  subTest     IQSubTest
  text        String          // Teks pertanyaan
  options     Json            // Array of { key: string, label: string }
  answerKey   String          // Kunci jawaban (A/B/C/D/E)
  imageUrl    String?         // Opsional: gambar soal
  isActive    Boolean         @default(true)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("iq_questions")
}

enum IQSubTest {
  VERBAL
  NUMERIC
  LOGIC
  SPATIAL
}

// Sub-test configuration (timer per sub-test)
model IQSubTestConfig {
  subTest     IQSubTest @id
  timeSeconds Int       @default(300)
  updatedAt   DateTime  @updatedAt

  @@map("iq_subtest_configs")
}

// ─── Psychometric & IQ Module ─────────────────────────────────────────────────

// Stores Big Five personality + integrity + stress + teamwork scores (per user, upsert)
model PsychometricResult {
  id                String   @id @default(cuid())
  userId            String   @unique
  // Big Five dimensions (normalized 0–100)
  openness          Float    @default(0)
  conscientiousness Float    @default(0)
  extraversion      Float    @default(0)
  agreeableness     Float    @default(0)
  neuroticism       Float    @default(0)
  // Additional PNS-specific dimensions
  integrity         Float    @default(0)
  stressResilience  Float    @default(0)
  teamwork          Float    @default(0)
  // Derived personality type label
  personalityType   String?
  // JSON blob: { positions: string[], instansi: string[] }
  careerRecs        Json?
  completedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("psychometric_results")
}

// Stores disaggregated IQ sub-scores (verbal, numeric, logic, spatial)
model IQResult {
  id             String   @id @default(cuid())
  userId         String   @unique
  // Raw correct answers per sub-test
  verbalRaw      Int      @default(0)
  numericRaw     Int      @default(0)
  logicRaw       Int      @default(0)
  spatialRaw     Int      @default(0)
  // Time taken per sub-test in seconds
  verbalTime     Int      @default(0)
  numericTime    Int      @default(0)
  logicTime      Int      @default(0)
  spatialTime    Int      @default(0)
  // Standardized IQ score (Mean=100, SD=15)
  totalIQ        Int      @default(100)
  // Interpretation label
  interpretation String?
  completedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("iq_results")
}

model Testimonial {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  guestName   String?
  guestRole   String?
  guestAvatar String?
  rating      Int      @default(5)
  content     String   @db.Text
  tags        String[]
  isVerified  Boolean  @default(false) // Untuk menandai real buyer
  isBackdoor  Boolean  @default(false) // Untuk tracking internal admin
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())

  @@map("testimonials")
}

model SystemConfig {
  id                    String  @id @default("global_config")
  showTestimonials      Boolean @default(true) // Global On/Off Toggle
  publicBackdoorEnabled Boolean @default(false) // Toggle for public backdoor link

  @@map("system_configs")
}
